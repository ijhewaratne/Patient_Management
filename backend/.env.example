# Copy this file to backend/.env before running the API locally.
#
# Generate a secure JWT secret with:
#   openssl rand -hex 32

SECRET_KEY=replace_with_a_secure_random_secret
FRONTEND_URL=http://localhost:3000

# Optional OpenAI-backed note processing features.
OPENAI_API_KEY=
OPENAI_STRUCTURING_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional local Whisper endpoint for privacy-first transcription.
LOCAL_WHISPER_URL=
LOCAL_WHISPER_MODEL=
LOCAL_WHISPER_LANGUAGE=en
